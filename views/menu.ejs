<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include("partials/nav") %>
    <main>
      <h1>Menu Items</h1>
      <form method="POST" action="/menu" class="card form-row">
        <input name="name" placeholder="Item name" required />
        <input name="description" placeholder="Description" required />
        <input name="price" type="number" min="0" step="0.01" placeholder="Price" required />
        <button type="submit">Add Item</button>
      </form>
      <table>
        <tr><th>ID</th><th>Name</th><th>Description</th><th>Price</th><th>Available</th><th>Action</th></tr>
        <% menuItems.forEach((m) => { %>
          <tr>
            <td><%= m.menu_item_id %></td>
            <td><%= m.name %></td>
            <td><%= m.description %></td>
            <td>$<%= Number(m.price).toFixed(2) %></td>
            <td><%= m.is_available ? "Yes" : "No" %></td>
            <td>
              <form method="POST" action="/menu/<%= m.menu_item_id %>/toggle">
                <button type="submit"><%= m.is_available ? "Disable" : "Enable" %></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </main>
  </body>
</html>
