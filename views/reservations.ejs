<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reservations</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include("partials/nav") %>
    <main>
      <h1>Reservations</h1>
      <form method="POST" action="/reservations" class="card form-row">
        <input name="reservation_time" type="datetime-local" required />
        <input name="party_size" type="number" min="1" placeholder="Party size" required />
        <input name="special_request" placeholder="Special request" />
        <select name="status">
          <option value="confirmed">confirmed</option>
          <option value="pending">pending</option>
          <option value="cancelled">cancelled</option>
        </select>
        <select name="customer_id" required>
          <option value="">Select customer</option>
          <% customers.forEach((c) => { %>
            <option value="<%= c.customer_id %>"><%= c.first_name %> <%= c.last_name %></option>
          <% }) %>
        </select>
        <select name="table_id" required>
          <option value="">Select table</option>
          <% tables.forEach((t) => { %>
            <option value="<%= t.table_id %>">Table <%= t.table_number %> (Cap <%= t.capacity %>)</option>
          <% }) %>
        </select>
        <button type="submit">Add Reservation</button>
      </form>

      <table>
        <tr><th>ID</th><th>Time</th><th>Customer</th><th>Table</th><th>Party</th><th>Status</th><th>Actions</th></tr>
        <% reservations.forEach((r) => { %>
          <tr>
            <td><%= r.reservation_id %></td>
            <td><%= r.reservation_time %></td>
            <td><%= r.customer_name %></td>
            <td><%= r.table_number %></td>
            <td><%= r.party_size %></td>
            <td><%= r.status %></td>
            <td class="actions">
              <form method="POST" action="/reservations/<%= r.reservation_id %>/status">
                <select name="status">
                  <option value="confirmed">confirmed</option>
                  <option value="pending">pending</option>
                  <option value="cancelled">cancelled</option>
                </select>
                <button type="submit">Update</button>
              </form>
              <form method="POST" action="/reservations/<%= r.reservation_id %>/delete">
                <button type="submit">Delete if cancelled</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </main>
  </body>
</html>
