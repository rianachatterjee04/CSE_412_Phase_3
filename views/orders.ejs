<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orders</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include("partials/nav") %>
    <main>
      <h1>Orders</h1>
      <form method="POST" action="/orders" class="card">
        <div class="form-row">
          <select name="customer_id" required>
            <option value="">Select customer</option>
            <% customers.forEach((c) => { %>
              <option value="<%= c.customer_id %>"><%= c.first_name %> <%= c.last_name %></option>
            <% }) %>
          </select>
          <select name="order_type" required>
            <option value="dine-in">dine-in</option>
            <option value="takeout">takeout</option>
            <option value="delivery">delivery</option>
          </select>
        </div>
        <p>Add up to 3 items for a quick demo:</p>
        <% for (let i = 0; i < 3; i += 1) { %>
          <div class="form-row">
            <select name="menu_item_id">
              <option value="">Select menu item</option>
              <% menuItems.forEach((m) => { %>
                <option value="<%= m.menu_item_id %>"><%= m.name %> - $<%= Number(m.price).toFixed(2) %></option>
              <% }) %>
            </select>
            <input name="quantity" type="number" min="1" value="1" />
          </div>
        <% } %>
        <button type="submit">Create Order</button>
      </form>
      <table>
        <tr><th>Order ID</th><th>Time</th><th>Type</th><th>Complete</th><th>Customer</th></tr>
        <% orders.forEach((o) => { %>
          <tr>
            <td><%= o.order_id %></td>
            <td><%= o.order_time %></td>
            <td><%= o.order_type %></td>
            <td><%= o.order_complete ? "Yes" : "No" %></td>
            <td><%= o.customer_name %></td>
          </tr>
        <% }) %>
      </table>
    </main>
  </body>
</html>
