<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dining Tables</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <%- include("partials/nav") %>
    <main>
      <h1>Dining Tables</h1>
      <form method="POST" action="/tables" class="card form-row">
        <input name="table_number" type="number" min="1" placeholder="Table number" required />
        <input name="capacity" type="number" min="1" placeholder="Capacity" required />
        <button type="submit">Add Table</button>
      </form>
      <table>
        <tr><th>ID</th><th>Table #</th><th>Capacity</th></tr>
        <% tables.forEach((t) => { %>
          <tr>
            <td><%= t.table_id %></td>
            <td><%= t.table_number %></td>
            <td><%= t.capacity %></td>
          </tr>
        <% }) %>
      </table>
    </main>
  </body>
</html>
